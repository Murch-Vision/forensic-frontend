# Copy this file to ".env" and edit it.
#
# Read at BUILD time, so re-run `npm run build` after changing it
# (scripts\self-update.bat rebuilds for you).

# Where the backend API is. Unset means http://localhost:4000 — this machine.
API_URL=http://localhost:4000

# Backend on another machine on the network:
# API_URL=http://192.168.1.50:4000

# Full endpoint override, only if GraphQL is not served at the host root:
# VITE_GRAPHQL_URL=http://localhost:4000/graphql
