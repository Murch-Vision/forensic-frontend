{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Forensic Analyst Workstation",
  "version": "3.2.0",
  "identifier": "mn.forensic.analyst",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg", "nsis", "msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/forensic-node"],
    "resources": ["sidecar/**/*"],
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  }
}
