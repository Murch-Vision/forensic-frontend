{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Permissions for the main window, including spawning the bundled API sidecar.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        { "name": "binaries/forensic-node", "sidecar": true, "args": true }
      ]
    },
    {
      "identifier": "shell:allow-kill",
      "allow": [
        { "name": "binaries/forensic-node", "sidecar": true, "args": true }
      ]
    }
  ]
}
