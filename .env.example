# Copy to .env and adjust. Read at BUILD time (npm run build / npm run start),
# so re-run the build after changing it.

# Where the backend API is. Default when unset: http://localhost:4000
# On-premise install, API on the same machine:
API_URL=http://localhost:4000

# API on another machine on the network:
# API_URL=http://192.168.1.50:4000

# Full endpoint override, only if GraphQL is not served at the host root:
# VITE_GRAPHQL_URL=http://localhost:4000/graphql
